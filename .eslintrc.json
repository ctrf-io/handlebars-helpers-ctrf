{
  "env": {
    "node": true,
    "es6": true,
    "mocha": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": 2018
  },
  "rules": {
    "no-console": "off",
    "strict": ["error", "global"],
    "semi": ["error", "always"],
    "no-unused-vars": "warn",
    "no-prototype-builtins": "warn",
    "no-useless-escape": "warn",
    "no-inner-declarations": "warn"
  },
  "ignorePatterns": [
    "test/**/*.js",
    "test/*.js",
    "verbfile.js"
  ]
}
