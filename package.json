  },
  "devDependencies": {
    "decache": "^4.6.2",
    "eslint": "^8.56.0",
    "fs-exists-sync": "^0.1.0",
    "global-modules": "^2.0.0",
    "is-descriptor": "^3.1.1",
    "js-yaml": "^4.1.0",
    "lodash": "^4.17.21",
    "markdown-link": "^0.1.1",
    "mocha": "^10.2.0",
    "mocha-ctrf-json-reporter": "^0.0.9",
