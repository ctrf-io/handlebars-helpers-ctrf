{
  "name": "handlebars-helpers-ctrf",
  "description": "Handlebars helpers to be used with CTRF libraries.",
  "version": "0.0.4-next.5",
  "homepage": "https://ctrf.io",
  "author": "Matthew Thomas",
  "contributors": [
    "Original authors and contributors of handlebars-helpers",
    "Matthew Thomas"
  ],
  "repository": "ctrf-io/handlebars-helpers-ctrf",
  "bugs": {
    "url": "https://github.com/mattthomas-info/handlebars-helpers-ctrf/issues"
  },
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "src",
    "THIRD_PARTY_LICENSES"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "npm run build && mocha \"dist/test/**/*.js\"",
    "test:coverage": "nyc mocha \"dist/test/**/*.js\"",
    "test:all": "npm run build && mocha dist/test",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "security": "npm audit || true",
    "prepublish": "npm run build",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "date.js": "^0.3.3",
    "gopd": "^1.2.0",
    "handlebars": "^4.7.8",
    "lazy-cache": "^2.0.2",
    "marked": "^4.3.0",
    "micromatch": "^4.0.5",
    "moment": "^2.30.1",
    "striptags": "^3.2.0"
  },
  "devDependencies": {
    "@types/handlebars": "^4.1.0",
    "@types/marked": "^4.0.8",
    "@types/micromatch": "^4.0.2",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "decache": "^4.6.2",
    "eslint": "^8.56.0",
    "fs-exists-sync": "^0.1.0",
    "global-modules": "^2.0.0",
    "is-descriptor": "^3.1.1",
    "js-yaml": "^4.1.0",
    "lodash": "^4.17.21",
    "markdown-link": "^0.1.1",
    "mocha": "^10.2.0",
    "mocha-ctrf-json-reporter": "^0.0.9",
    "mocha-multi-reporters": "^1.5.1",
    "nyc": "^15.1.0",
    "prettier": "^3.1.1",
    "should": "^13.2.3",
    "typescript": "^5.3.3"
  },
  "resolutions": {
    "lodash.template": "^4.5.0",
    "lodash": "^4.17.21",
    "braces": "^3.0.3",
    "minimatch": "^3.0.5",
    "nanoid": "^3.3.7"
  },
  "keywords": [
    "handlebars",
    "helpers",
    "typescript",
    "ctrf"
  ]
}
